  local var_0: void, y_1: int, x_2: .rust_mut = "const" .rust_pointer = "reference" *int
  #node_0:
      store &var_0 <- null:void
      store &y_1 <- 10:int
      store &x_2 <- &y_1:.rust_mut = "const" .rust_pointer = "reference" *int
      n0 = __rust_retag(&x_2, &y_1, 0)
